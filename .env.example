# =============================================================================
# kaji-note — 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、実際の値を入力してください。
#   cp .env.example .env.local
#
# EXPO_PUBLIC_* プレフィックスの変数は JS バンドルに含まれます。
# Supabase の anon key は RLS により保護されているため公開可能です。
# GEMINI_API_KEY はクライアントには置かず Supabase Edge Functions のみに設定します。
# =============================================================================

# Supabase — Supabase Dashboard > Settings > API から取得
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 閲覧専用リンクのベース URL — Expo Web ビルドのデプロイ先（末尾スラッシュなし）
# 例: https://kaji-note.vercel.app
# 共有 URL 形式: {EXPO_PUBLIC_SHARE_BASE_URL}/share/{token}
EXPO_PUBLIC_SHARE_BASE_URL=https://your-deploy-domain.example.com

# EAS Build — expo.dev のプロジェクト設定から取得（ローカル開発では不要）
EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
